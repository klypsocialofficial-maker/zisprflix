{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "createdAt": {
          "type": "integer"
        }
      },
      "required": [
        "email",
        "createdAt"
      ]
    }
  },
  "firestore": {
