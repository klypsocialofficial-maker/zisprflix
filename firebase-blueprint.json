{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "createdAt": {
          "type": "integer"
        }
      },
      "required": [
        "email",
        "createdAt"
      ]
    },
    "Profile": {
      "title": "Profile",
      "description": "A viewer profile for the user account",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "avatarUrl": {
          "type": "string"
        },
        "createdAt": {
          "type": "integer"
        }
      },
      "required": [
        "name",
        "avatarUrl",
        "createdAt"
      ]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "User profiles",
      "collections": {
        "profiles/{profileId}": {
          "schema": {
            "$ref": "#/entities/Profile"
          },
          "description": "Viewer profiles tied to a user account"
        }
      }
    }
  }
}
